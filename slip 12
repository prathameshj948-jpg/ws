<html>
<body>

<form method="post">
String 1: <input type="text" name="s1"><br><br>
String 2: <input type="text" name="s2"><br><br>

<input type="radio" name="op" value="compare">Compare<br>
<input type="radio" name="op" value="upper">Uppercase<br>
<input type="radio" name="op" value="lower">Lowercase<br><br>

<input type="submit" value="Submit">
</form>

<?php
if($_POST){
    $s1 = $_POST['s1'];
    $s2 = $_POST['s2'];
    $op = $_POST['op'];

    if($op == "compare"){
        if($s1 == $s2){
            echo "Strings are Equal";
        } else {
            echo "Strings are Not Equal";
        }
    }

    if($op == "upper"){
        echo strtoupper($s1);
    }

    if($op == "lower"){
        echo strtolower($s1);
    }
}
?>

</body>
</html>
