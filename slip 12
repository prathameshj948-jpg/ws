<?php
function cylinder($r, $h){
    $area = 2 * 3.14 * $r * ($r + $h);
    $volume = 3.14 * $r * $r * $h;

    echo "Surface Area: $area <br>";
    echo "Volume: $volume";
}

if($_POST){
    $r = $_POST['r'];
    $h = $_POST['h'];
    cylinder($r, $h);
}
?>

